{
  "name": "hindu-saints-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run db:start && node scripts/prepare-next-dev.mjs && prisma migrate deploy && prisma generate",
    "dev": "next dev",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "dev:reset": "npm run dev:stop && npm run dev",
    "build:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-local.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "dev:check": "prisma generate && tsc --noEmit",
    "verify": "npm run db:generate && npm run build",
    "codex:verify": "npm run db:generate && npm run build",
    "db:generate": "prisma generate",
    "db:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "import:airtable": "tsx scripts/import-airtable.ts",
    "import:airtable-saints": "tsx scripts/import-airtable-saints-to-cms.ts",
    "import:airtable-gurus": "tsx scripts/import-airtable-guru-relationships.ts",
    "merge:airtable": "tsx scripts/merge-airtable-duplicates.ts",
    "reconcile:airtable": "tsx scripts/reconcile-airtable.ts",
    "ingest:instagram": "tsx scripts/ingest-instagram.ts",
    "cache:instagram-media": "tsx scripts/cache-instagram-media.ts",
    "cache:instagram-covers": "tsx scripts/cache-instagram-cover-images.ts",
    "backfill:instagram-carousels": "tsx scripts/backfill-instagram-carousel-images.ts",
    "reconcile:instagram": "tsx scripts/reconcile-instagram.ts",
    "create-admin": "tsx scripts/create-admin-user.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.468.0",
    "next": "^15.0.3",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
